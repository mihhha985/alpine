{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Products"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Title": {
      "type": "string",
      "minLength": 10,
      "maxLength": 100,
      "required": true
    },
    "Description": {
      "type": "text",
      "minLength": 20,
      "required": true
    },
    "Price": {
      "type": "decimal",
      "required": true,
      "default": 0
    },
    "MainImg": {
      "type": "media",
      "multiple": false,
      "required": false
    },
    "Images": {
      "type": "media",
      "multiple": true
    },
    "Badge": {
      "type": "enumeration",
      "enum": [
        "эксклюзив",
        "новая коллекция"
      ]
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "products"
    },
    "sub_category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::sub-category.sub-category",
      "inversedBy": "products"
    },
    "colors": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::color.color",
      "mappedBy": "products"
    },
    "sizes": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::size.size",
      "inversedBy": "products"
    },
    "brand": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::brand.brand",
      "inversedBy": "products"
    }
  }
}
