{
  "kind": "collectionType",
  "collectionName": "colors",
  "info": {
    "singularName": "color",
    "pluralName": "colors",
    "displayName": "Color"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Title": {
      "type": "string",
      "minLength": 5,
      "maxLength": 20,
      "required": true,
      "unique": true
    },
    "HEX": {
      "type": "string",
      "required": true,
      "unique": true,
      "regex": "^#[0-9A-Fa-f]{6}$"
    },
    "products": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::product.product",
      "inversedBy": "colors"
    }
  }
}
